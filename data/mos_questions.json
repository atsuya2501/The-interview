{
  "schema_name": "mos_questions",
  "version": "0.1_skeleton",
  "title": "明治国際医療大学弁証スコア(MOS)",
  "description": "51問の固定アンケート。各問を3段階(常にある=2/時々ある=1/ない=0)で回答。加点式で気血陰陽・五臓の弁証プロファイルを算出。西洋鑑別アプリとは別ページだがtcm_findings_schemaを共有。",
  "design_notes": {
    "type": "fixed_questionnaire",
    "logic": "条件分岐なし。51問全回答→四則演算→弁証プロファイル(グラフ)。西洋アプリの除外診断とは逆の加点式プロファイリング。",
    "shared_resource": "脈・舌・冷えなど一部の問はtcm_findings_schemaと入力共有。MOSで集めた所見が西洋カルテの刺激量決定にも流れる(前セッションの伏線回収)。",
    "output_philosophy": "確定でなく全証のプロファイル提示。西洋アプリの示唆思想と一貫。"
  },
  "scale": {
    "常にある": 2,
    "時々ある": 1,
    "ない": 0,
    "M_scale_note": "[M]スケール(問28-30等)は2点/1点で判定。月経のある女性のみ回答するL項目あり。",
    "F_scale_note": "[F]スケール該当項目は別途1点/0点で判定(原著の指示に従う)。"
  },
  "sections": [
    {"section": "A", "label": "側頭部・頭頂部の頭痛", "questions": [
      {"no": 1, "text": "側頭部・頭頂部の頭痛", "tcm_ref": null},
      {"no": 2, "text": "口が苦い"},
      {"no": 3, "text": "目の症状(かすみ・疲れ・乾燥感)"},
      {"no": 4, "text": "こむら返り"},
      {"no": 5, "text": "イライラしやすい、または怒りっぽい"},
      {"no": 6, "text": "酸っぱいものが食べたい"}
    ]},
    {"section": "B", "label": "(心)", "questions": [
      {"no": 7, "text": "夢を多く見る"},
      {"no": 8, "text": "舌がしびれる"},
      {"no": 9, "text": "動悸し息切れする"},
      {"no": 10, "text": "脈がとぶ", "tcm_ref": "tcm_findings.pulse"},
      {"no": 11, "text": "胸の圧迫感、しめつけや痛み"},
      {"no": 12, "text": "苦いものが食べたい"}
    ]},
    {"section": "C", "label": "(脾)", "questions": [
      {"no": 13, "text": "食欲がない"},
      {"no": 14, "text": "腹部膨満感(みぞおちの痛み、もたれ、不快感)"},
      {"no": 15, "text": "皮下出血が起こりやすい"},
      {"no": 16, "text": "味がわかりにくい"},
      {"no": 17, "text": "便が柔らかい"},
      {"no": 18, "text": "甘いものが食べたい"}
    ]},
    {"section": "D", "label": "(肺)", "questions": [
      {"no": 19, "text": "咳または咳と痰"},
      {"no": 20, "text": "息苦しい"},
      {"no": 21, "text": "鼻の症状(鼻水・鼻づまりなど)"},
      {"no": 22, "text": "喉の痛み"},
      {"no": 23, "text": "乾燥肌", "tcm_ref": null},
      {"no": 24, "text": "辛いものが食べたい"}
    ]},
    {"section": "E", "label": "(腎)", "questions": [
      {"no": 25, "text": "耳が遠い"},
      {"no": 26, "text": "足腰がだるい"},
      {"no": 27, "text": "夜間尿(2回以上)"},
      {"no": 28, "text": "排尿異常(多い・少ない・出にくいなど)"},
      {"no": 29, "text": "最近髪の毛が抜ける"},
      {"no": 30, "text": "塩辛いものが食べたい"}
    ]},
    {"section": "F", "label": "(気虚)", "questions": [
      {"no": 31, "text": "疲れやすい"},
      {"no": 32, "text": "気力(やる気)がない"},
      {"no": 33, "text": "じっとしていても汗が出る"}
    ]},
    {"section": "G", "label": "(陽虚)", "questions": [
      {"no": 34, "text": "寒がり"},
      {"no": 35, "text": "手または足が冷える", "tcm_ref": null},
      {"no": 36, "text": "温かいものを好む"}
    ]},
    {"section": "H", "label": "(陰虚)", "questions": [
      {"no": 37, "text": "手または足のほてり"},
      {"no": 38, "text": "冷たいものが好き"},
      {"no": 39, "text": "よく寝汗をかく"}
    ]},
    {"section": "I", "label": "(血虚)", "questions": [
      {"no": 40, "text": "爪の色が白っぽい、変形", "tcm_ref": null},
      {"no": 41, "text": "髪に艶がない"},
      {"no": 42, "text": "肌にツヤがなく荒れている"}
    ]},
    {"section": "J", "label": "(気滞)", "questions": [
      {"no": 43, "text": "げっぷやおならをすると症状が楽になる"},
      {"no": 44, "text": "はったような痛み(腹・胸脇など)"},
      {"no": 45, "text": "症状が同じ部位にとどまらず、いろいろな部位に移動する"}
    ]},
    {"section": "K", "label": "(血瘀)", "questions": [
      {"no": 46, "text": "同じ場所に刺すような痛みがある"},
      {"no": 47, "text": "口唇、舌が青紫色をしている", "tcm_ref": "tcm_findings.tongue.color"},
      {"no": 48, "text": "目の周りが黒い"}
    ]},
    {"section": "L", "label": "(月経のある女性のみ)", "conditional": "female_with_menstruation", "questions": [
      {"no": 49, "text": "不正性器出血"},
      {"no": 50, "text": "月経量が少ない"},
      {"no": 51, "text": "黒紫色の出血に血の塊が混じる"}
    ]}
  ]
}
